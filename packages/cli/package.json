{
  "name": "@replyke/cli",
  "version": "7.0.0",
  "description": "CLI for installing Replyke UI components",
  "type": "module",
  "bin": {
    "replyke": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "prompts": "^2.4.2",
    "chalk": "^5.6.2",
    "ora": "^9.3.0",
    "fs-extra": "^11.3.4",
    "node-fetch": "^3.3.2",
    "execa": "^9.6.1",
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/plugin-syntax-jsx": "^7.28.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "@types/fs-extra": "^11.0.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
